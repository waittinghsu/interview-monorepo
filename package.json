{
  "name": "interview-monorepo",
  "private": true,
  "scripts": {
    "dev:vue": "turbo run dev --filter=@interview/vue-app",
    "dev:nuxt": "turbo run dev --filter=@interview/nuxt-app",
    "dev:smartauto": "turbo run dev --filter=@interview/smartauto-nuxt-app",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:vue": "turbo run build --filter=...@interview/vue-app",
    "build:nuxt": "turbo run build --filter=...@interview/nuxt-app",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.4"
}