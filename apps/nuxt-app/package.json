{
  "name": "@interview/nuxt-app",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf .nuxt .output node_modules"
  },
  "dependencies": {
    "@interview/shared-api": "workspace:*",
    "@interview/shared-design-tokens": "workspace:*",
    "@interview/shared-mocks": "workspace:*",
    "@interview/shared-utils": "workspace:*",
    "@pinia/nuxt": "^0.5.5",
    "@quasar/extras": "^1.16.0",
    "@tanstack/vue-query": "^5.62.16",
    "@vueuse/nuxt": "^12.4.0",
    "axios": "^1.7.9",
    "lightweight-charts": "^5.1.0",
    "nuxt": "^3.15.1",
    "nuxt-quasar-ui": "^2.1.8",
    "pinia": "^2.3.0",
    "quasar": "^2.17.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.0.0",
    "@iconify-json/carbon": "^1.2.0",
    "@iconify-json/mdi": "^1.2.0",
    "@unocss/nuxt": "^66.6.0",
    "eslint": "^9.18.0",
    "sass-embedded": "^1.83.4",
    "typescript": "^5.7.3",
    "vue-tsc": "^2.2.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
