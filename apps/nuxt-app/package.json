{
  "name": "@interview/nuxt-app",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "dev:stage": "nuxt dev --dotenv .env.staging",
    "local:proc": "nuxt dev",
    "build": "nuxt build",
    "build:stage": "nuxt build --dotenv .env.staging",
    "preview": "nuxt preview",
    "preview:stage": "nuxt preview --dotenv .env.staging",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .nuxt .output node_modules"
  },
  "dependencies": {
    "@interview/shared-api": "workspace:*",
    "@interview/shared-design-tokens": "workspace:*",
    "@interview/shared-mocks": "workspace:*",
    "@interview/shared-utils": "workspace:*",
    "@nuxtjs/i18n": "^9.2.0",
    "@pinia/nuxt": "^0.5.5",
    "@quasar/extras": "^1.16.0",
    "@tanstack/vue-query": "^5.62.16",
    "@types/highlight.js": "^10.1.0",
    "@vueuse/components": "^12.4.0",
    "@vueuse/nuxt": "^12.4.0",
    "@zumer/snapdom": "^2.0.2",
    "animejs-v4": "npm:animejs@^4.2.2",
    "axios": "^1.7.9",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.1.0",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "lightweight-charts": "^5.1.0",
    "nuxt": "^3.15.1",
    "nuxt-quasar-ui": "^2.1.8",
    "pinia": "^2.3.0",
    "quasar": "^2.17.7",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.0.0",
    "@iconify-json/carbon": "^1.2.0",
    "@iconify-json/mdi": "^1.2.0",
    "@unocss/nuxt": "^66.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^9.18.0",
    "happy-dom": "^20.8.8",
    "sass-embedded": "^1.83.4",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
