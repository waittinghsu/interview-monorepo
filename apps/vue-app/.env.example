# API Base URL（後端 API）
VITE_API_BASE_URL=/api

# YAPI Mock 全域緊急開關（預設 false，使用真實後端）
# 僅在後端服務掛掉/無法使用時才設為 true，全站降級到 YAPI mock
# 可透過 API 呼叫時的 options.useYApiMock 個別覆蓋
VITE_USE_YAPI_MOCK=false

# YAPI Mock Server URL
VITE_YAPI_BASE_URL=https://yapi-x.zeabur.app/mock/18

# App Title
VITE_APP_TITLE=Interview Vue